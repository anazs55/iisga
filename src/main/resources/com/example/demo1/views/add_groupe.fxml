<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #154697; -fx-border-width: 2;" prefWidth="350" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="Nouveau Groupe" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #154697;" />
    
    <VBox spacing="10">
        <Label text="Nom du Groupe :" />
        <TextField fx:id="txtNomGroupe" promptText="ex: TSDI 201" />
        
        <Label text="Niveau :" />
        <ComboBox fx:id="comboNiveau" prefWidth="Infinity" />
        
        <Label text="Effectif (Nombre d'étudiants) :" />
        <TextField fx:id="txtEffectif" promptText="ex: 25" />
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" style="-fx-background-color: #cbd5e1;" />
        <Button text="Enregistrer" style="-fx-background-color: #154697; -fx-text-fill: white;" />
    </HBox>
</VBox>