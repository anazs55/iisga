<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20;" styleClass="app-root" stylesheets="@style.css" prefWidth="350" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.controllers.AddDialogController">
    <Label text="Nouvelle Salle" styleClass="label-primary label-accent" />
    
    <GridPane vgap="10" hgap="10">
        <Label text="Nom/N° :" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="txtNomSalle" GridPane.rowIndex="0" GridPane.columnIndex="1" />
        
        <Label text="Capacité :" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="txtCapacite" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        
        <Label text="Type :" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboTypeSalle" prefWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1" />
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" styleClass="btn-secondary" onAction="#handleCancel" />
        <Button text="Enregistrer" styleClass="btn-primary" onAction="#handleSave" />
    </HBox>
</VBox>
