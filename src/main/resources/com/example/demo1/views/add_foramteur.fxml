<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20;" styleClass="app-root" stylesheets="@style.css" prefWidth="400" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.controllers.AddDialogController">
    <Label text="Ajouter un Formateur" styleClass="label-primary label-accent" />
    
    <GridPane vgap="10" hgap="10">
        <Label text="Nom:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="txtNom" GridPane.rowIndex="0" GridPane.columnIndex="1" HBox.hgrow="ALWAYS" />
        
        <Label text="Prénom:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="txtPrenom" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        
        <Label text="Spécialité:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboSpecialite" prefWidth="200" GridPane.rowIndex="2" GridPane.columnIndex="1" />
        
        <Label text="Email:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <TextField fx:id="txtEmail" GridPane.rowIndex="3" GridPane.columnIndex="1" />
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Annuler" styleClass="btn-secondary" onAction="#handleCancel" />
        <Button text="Enregistrer" styleClass="btn-primary" onAction="#handleSave" />
    </HBox>
</VBox>
