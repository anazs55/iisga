<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #d32f2f; -fx-border-width: 1;" prefWidth="450" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="Planification d'Examen" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #d32f2f;" />
    
    <GridPane vgap="12" hgap="15">
        <Label text="Type d'examen :" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
        <HBox spacing="20" GridPane.rowIndex="0" GridPane.columnIndex="1">
            <RadioButton text="Normal" fx:id="rbNormal" selected="true">
                <toggleGroup><ToggleGroup fx:id="groupType"/></toggleGroup>
            </RadioButton>
            <RadioButton text="Rattrapage" fx:id="rbRattrapage" toggleGroup="$groupType" />
        </HBox>

        <Label text="Module :" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboModuleEx" prefWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        
        <Label text="Groupe :" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboGroupeEx" prefWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1" />
        
        <Label text="Salle :" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboSalleEx" prefWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1" />
        
        <Label text="Date &amp; Heure :" GridPane.rowIndex="4" GridPane.columnIndex="0" />
        <HBox spacing="10" GridPane.rowIndex="4" GridPane.columnIndex="1">
            <DatePicker fx:id="dateExamen" prefWidth="150" />
            <TextField fx:id="heureExamen" promptText="14:00" prefWidth="80" />
        </HBox>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Fermer" />
        <Button text="Confirmer l'examen" style="-fx-background-color: #d32f2f; -fx-text-fill: white;" />
    </HBox>
</VBox>