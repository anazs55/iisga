<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox style="-fx-background-color: #f4f7fb;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.ModulesController">

    <VBox spacing="20" style="-fx-padding: 25;" HBox.hgrow="ALWAYS">

        <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #154697;" text="Gestion des Modules" />

        <HBox spacing="10">
            <Button style="-fx-background-color: #6eb530; -fx-text-fill: white;" text="➕ Ajouter" />
            <Button style="-fx-background-color: #154697; -fx-text-fill: white;" text="✏ Modifier" />
            <Button style="-fx-background-color: #d32f2f; -fx-text-fill: white;" text="🗑 Supprimer" />
        </HBox>

        <HBox spacing="20">

            <!-- TABLE -->
            <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold;" text="Liste des Modules" />

                <TableView fx:id="tableModules" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="80" text="ID" />
                        <TableColumn fx:id="colNom" prefWidth="150" text="Nom Module" />
                        <TableColumn fx:id="colDuree" prefWidth="120" text="Durée (h)" />
                    </columns>
                </TableView>
            </VBox>

        </HBox>

    </VBox>

</HBox>
