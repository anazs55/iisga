<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.DashboardController"
      style="-fx-background-color: #f4f7fb;">

    <!-- ================= MAIN ================= -->
    <VBox spacing="20" HBox.hgrow="ALWAYS" style="-fx-padding: 25;">

        <!-- TITLE -->
        <Label text="Bienvenue Admin !"
               style="-fx-font-size: 22px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #154697;" />

        <!-- ================= STATS ================= -->
        <HBox spacing="15">

            <!-- CARD -->
            <VBox spacing="8"
                  style="-fx-background-color: white;
                         -fx-padding: 15;
                         -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,3);">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ImageView fitHeight="18" fitWidth="18">
                        <image><Image url="@icons/salles.png"/></image>
                    </ImageView>

                    <VBox>
                        <Label text="Salles"
                               style="-fx-text-fill: gray;"/>
                        <Label fx:id="salleCount" text="0"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #154697;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- CARD -->
            <VBox spacing="8"
                  style="-fx-background-color: white;
                         -fx-padding: 15;
                         -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,3);">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ImageView fitHeight="18" fitWidth="18">
                        <image><Image url="@icons/professeurs.png"/></image>
                    </ImageView>

                    <VBox>
                        <Label text="Professeurs"
                               style="-fx-text-fill: gray;"/>
                        <Label fx:id="profCount" text="0"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #154697;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- CARD -->
            <VBox spacing="8"
                  style="-fx-background-color: white;
                         -fx-padding: 15;
                         -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,3);">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ImageView fitHeight="18" fitWidth="18">
                        <image><Image url="@icons/groupes.png"/></image>
                    </ImageView>

                    <VBox>
                        <Label text="Groupes"
                               style="-fx-text-fill: gray;"/>
                        <Label fx:id="groupeCount" text="0"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #154697;"/>
                    </VBox>
                </HBox>
            </VBox>

        </HBox>

        <!-- ================= TASKS ================= -->
        <HBox spacing="20">

            <!-- ACTIONS -->
            <VBox spacing="15" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-padding: 20;
                         -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,3);">

                <Label text="Raccourcis de Tâches"
                       style="-fx-font-weight: bold;
                              -fx-text-fill: #154697;"/>

                <HBox spacing="12">

                    <!-- BUTTON -->
                    <Button text="Importer"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #6eb530;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-padding: 8 12;">
                        <graphic>
                            <ImageView fitHeight="20" fitWidth="20">
                                <image><Image url="@icons/importer.png"/></image>
                            </ImageView>
                        </graphic>
                    </Button>

                    <!-- BUTTON -->
                    <Button text="Générer"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #6eb530;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-padding: 8 12;">
                        <graphic>
                            <ImageView fitHeight="20" fitWidth="20">
                                <image><Image url="@icons/gerer.png"/></image>
                            </ImageView>
                        </graphic>
                    </Button>

                    <!-- BUTTON -->
                    <Button text="Exporter"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #6eb530;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-padding: 8 12;">
                        <graphic>
                            <ImageView fitHeight="20" fitWidth="20">
                                <image><Image url="@icons/exporter.png"/></image>
                            </ImageView>
                        </graphic>
                    </Button>

                </HBox>

            </VBox>

            <!-- STATUS -->
            <VBox spacing="12" prefWidth="260"
                  style="-fx-background-color: white;
                         -fx-padding: 20;
                         -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,3);">

                <Label text="Statut des Tâches"
                       style="-fx-font-weight: bold;
                              -fx-text-fill: #154697;"/>

                <Label fx:id="importStatus" text="❌ Importation des données"
                       style="-fx-text-fill: #d32f2f;"/>

                <Label fx:id="generateStatus" text="❌ Génération des emplois du temps"
                       style="-fx-text-fill: #d32f2f;"/>

            </VBox>

        </HBox>

    </VBox>

</HBox>