<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.SeancesController"
      style="-fx-background-color: #f4f7fb;">

    <VBox spacing="20" HBox.hgrow="ALWAYS" style="-fx-padding: 25;">

        <!-- TITLE -->
        <Label text="Gestion des Séances"
               style="-fx-font-size: 22px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #154697;" />

        <!-- ACTIONS -->
        <HBox spacing="10">
            <Button text="➕ Ajouter"
                    onAction="#handleAdd"
                    style="-fx-background-color: #6eb530; -fx-text-fill: white;" />

            <Button text="🗑 Supprimer"
                    onAction="#handleDelete"
                    style="-fx-background-color: #d32f2f; -fx-text-fill: white;" />
        </HBox>

        <!-- CONTENT -->
        <HBox spacing="20">

            <!-- TABLE -->
            <VBox HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-padding: 15;
                         -fx-background-radius: 12;">

                <Label text="Liste des Séances"
                       style="-fx-font-weight: bold;" />

                <TableView fx:id="tableSeances" prefHeight="400">

                    <columns>
                        <TableColumn fx:id="colFormateur" text="Formateur" prefWidth="120"/>
                        <TableColumn fx:id="colSalle" text="Salle" prefWidth="100"/>
                        <TableColumn fx:id="colGroupe" text="Groupe" prefWidth="100"/>
                        <TableColumn fx:id="colModule" text="Module" prefWidth="120"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                        <TableColumn fx:id="colDebut" text="Début" prefWidth="80"/>
                        <TableColumn fx:id="colFin" text="Fin" prefWidth="80"/>
                    </columns>

                </TableView>
            </VBox>

        </HBox>

    </VBox>

</HBox>