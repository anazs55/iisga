<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.controllers.SeancesController"
      style="-fx-background-color: #f4f7fb;"
      styleClass="app-root"
      stylesheets="@style.css">

    <VBox spacing="20" HBox.hgrow="ALWAYS" style="-fx-padding: 25;">

        <!-- TITLE -->
        <Label text="Gestion des Séances"
               styleClass="label-primary" />

        <!-- ACTIONS -->
        <HBox spacing="10">
            <Button text="➕ Ajouter"
                    onAction="#handleAdd"
                    styleClass="btn-success" />

            <Button text="🗑 Supprimer"
                    onAction="#handleDelete"
                    styleClass="btn-danger" />
        </HBox>

        <!-- CONTENT -->
        <HBox spacing="20">

            <!-- TABLE -->
            <VBox HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-padding: 15;
                         -fx-background-radius: 12;">

                <Label text="Liste des Séances"
                       styleClass="section-title" />

                <TableView fx:id="tableSeances" prefHeight="400">

                    <columns>
                        <TableColumn fx:id="colFormateur" text="Formateur" prefWidth="120"/>
                        <TableColumn fx:id="colSalle" text="Salle" prefWidth="100"/>
                        <TableColumn fx:id="colGroupe" text="Groupe" prefWidth="100"/>
                        <TableColumn fx:id="colModule" text="Module" prefWidth="120"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                        <TableColumn fx:id="colDebut" text="Début" prefWidth="80"/>
                        <TableColumn fx:id="colFin" text="Fin" prefWidth="80"/>
                    </columns>

                </TableView>
            </VBox>

        </HBox>

    </VBox>

</HBox>
