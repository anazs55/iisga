<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox style="-fx-background-color: #f4f7fb;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.FormateursController">

    <!-- ================= MAIN ================= -->
    <VBox spacing="20" style="-fx-padding: 25;" HBox.hgrow="ALWAYS">

        <!-- TITLE -->
        <Label style="-fx-font-size: 22px;                       -fx-font-weight: bold;                       -fx-text-fill: #154697;" text="Gestion des Formateurs" />

        <!-- ================= ACTIONS ================= -->
        <HBox spacing="10">

            <Button style="-fx-background-color: #6eb530;                            -fx-text-fill: white;                            -fx-background-radius: 8;" text="➕ Ajouter" />

            <Button style="-fx-background-color: #154697;                            -fx-text-fill: white;                            -fx-background-radius: 8;" text="✏ Modifier" />

            <Button style="-fx-background-color: #d32f2f;                            -fx-text-fill: white;                            -fx-background-radius: 8;" text="🗑 Supprimer" />

        </HBox>

        <!-- ================= CONTENT ================= -->
        <HBox spacing="20">

            <!-- TABLE -->
            <VBox style="-fx-background-color: white;                          -fx-padding: 15;                          -fx-background-radius: 12;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,3);" HBox.hgrow="ALWAYS">

                <Label style="-fx-font-weight: bold;                               -fx-text-fill: #154697;" text="Liste des Formateurs" />

                <TableView fx:id="tableFormateurs" prefHeight="400">

                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                        <TableColumn fx:id="colNom" prefWidth="120" text="Nom" />
                        <TableColumn fx:id="colPrenom" prefWidth="120" text="Prénom" />
                        <TableColumn fx:id="colEmail" prefWidth="180" text="Email" />
                        <TableColumn fx:id="colTelephone" prefWidth="120" text="Téléphone" />
                    </columns>

                </TableView>

            </VBox>

        </HBox>

    </VBox>

</HBox>
