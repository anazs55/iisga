<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20;" prefWidth="450" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="Nouvelle Séance de Cours" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #154697;" />
    
    <GridPane vgap="12" hgap="15">
        <Label text="Module :" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboModule" prefWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1" />
        
        <Label text="Formateur :" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboFormateur" prefWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        
        <Label text="Groupe :" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboGroupe" prefWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1" />
        
        <Label text="Salle :" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboSalle" prefWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1" />
        
        <Label text="Date :" GridPane.rowIndex="4" GridPane.columnIndex="0" />
        <DatePicker fx:id="datePicker" prefWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1" />
        
        <HBox spacing="10" GridPane.rowIndex="5" GridPane.columnIndex="1">
            <VBox>
                <Label text="Début" style="-fx-font-size: 10;" />
                <TextField fx:id="txtHeureDebut" promptText="08:30" prefWidth="80" />
            </VBox>
            <VBox>
                <Label text="Fin" style="-fx-font-size: 10;" />
                <TextField fx:id="txtHeureFin" promptText="10:30" prefWidth="80" />
            </VBox>
        </HBox>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Annuler" style="-fx-background-color: #cbd5e1;" />
        <Button text="Ajouter au planning" style="-fx-background-color: #6eb530; -fx-text-fill: white;" />
    </HBox>
</VBox>